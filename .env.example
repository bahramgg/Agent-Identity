# Agent Identity — environment

# LIVE mode is enabled only when a Speculos emulator is reachable.
# Leave SPECULOS_URL unset to force DEMO mode (e.g. on Render).
#
# Local LIVE mode: run Speculos with the Ethereum app on port 5000, then set:
# SPECULOS_URL=http://localhost:5000

# SPECULOS_URL=http://localhost:5000

# Optional: override the BIP-32 derivation path used for the identity key.
# Defaults to the standard Ethereum account 0 path.
# LEDGER_DERIVATION_PATH=44'/60'/0'/0/0
